{
  "name": "ascii-art-ai",
  "description": "Ascii Art Ai tools powered by MEOK AI Labs.",
  "version": "1.0.0",
  "protocol_version": "2025-11-25",
  "publisher": {
    "name": "MEOK AI Labs",
    "url": "https://meok.ai",
    "email": "nicholas@meok.ai"
  },
  "repository": "https://github.com/CSOAI-ORG/ascii-art-ai-mcp",
  "license": "MIT",
  "transport": [
    "stdio",
    "streamable-http"
  ],
  "authentication": {
    "type": "api-key",
    "free_tier": true,
    "free_limit": "15 calls/day"
  },
  "tools": [
