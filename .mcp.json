{
  "name": "ascii-art-ai-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 MEOK AI Labs MCP Server",
  "version": "1.0.0",
  "tools": [
    {
      "name": "text_to_ascii",
      "description": "Convert text to ASCII art using built-in block font.",
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "font": {
            "type": "string"
          }
        },
        "required": [
          "text"
        ]
      }
    },
    {
      "name": "generate_box",
      "description": "Generate a box around text with various border styles.",
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "style": {
            "type": "string"
          },
          "padding": {
            "type": "integer"
          },
          "width": {
            "type": "integer"
          }
        },
        "required": [
          "text"
        ]
      }
    },
    {
      "name": "table_formatter",
      "description": "Format data as an ASCII table.",
      "parameters": {
        "type": "object",
        "properties": {
          "headers": {
            "type": "array"
          },
          "rows": {
            "type": "array"
          },
          "style": {
            "type": "string"
          }
        },
        "required": [
          "headers",
          "rows"
        ]
      }
    },
    {
      "name": "progress_bar_generator",
      "description": "Generate an ASCII progress bar.",
      "parameters": {
        "type": "object",
        "properties": {
          "progress": {
            "type": "number"
          },
          "width": {
            "type": "integer"
          },
          "style": {
            "type": "string"
          }
        },
        "required": [
          "progress"
        ]
      }
    }
  ]
}